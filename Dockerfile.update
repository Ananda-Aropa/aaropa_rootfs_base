FROM ghcr.io/ananda-aropa/aaropa_rootfs_base@sha256:09ad44a88672ef56ed00ba0c6322d0ad991580f6f2672d357858c942d723e1cb AS final

COPY template /
COPY packages /

RUN apt update
RUN grep -Ev '^#' /pkglist.cfg | xargs apt install -y --no-install-recommends --no-install-suggests --allow-unauthenticated
RUN apt full-upgrade -y --allow-unauthenticated

# Uninstall unnecessary packages
RUN apt autoremove --purge -y

# Clean up cache & files
RUN apt autoclean && rm -rf /var/lib/apt/lists/*
RUN rm /*.cfg